# BSP Kafka GC Analyzer — environment configuration
# Copy to .env and adjust. manage-app.sh and gcanalyzer load this on startup.
# Existing shell env vars always take precedence over .env values.

# --- Database & scheduler ---
# GC_DB=gc_history.db
# GC_SCHED_ENABLED=1
# GC_SCHED_INTERVAL=300
# GC_RETENTION_DAYS=730

# --- Last-hour alert thresholds (fleet UI) ---
GC_ALERT_PAUSE_MS=400
GC_ALERT_P99_MS=150
GC_ALERT_HEAP_PCT=80
GC_ALERT_STORM_TIG_PCT=3
GC_ALERT_STORM_MULT=2.5
GC_ALERT_GC_FREQ_MIN=15
GC_ALERT_WINDOW_S=1800
